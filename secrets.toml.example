# ---------------------------------------------------------------------------
#  .streamlit/secrets.toml  —  TEMPLATE
# ---------------------------------------------------------------------------
#  Fill this in locally and NEVER commit the real file to version control.
#  (Add `.streamlit/secrets.toml` to your .gitignore.)
#
#  Two ways to connect, pick ONE:
#
#  A) Service Account (recommended for production / private sheets)
#  B) Public sheet by URL (read-only, no write-back) — for quick demos only
# ---------------------------------------------------------------------------

[connections.gsheets]
# The full URL of your Google Sheet:
spreadsheet = "https://docs.google.com/spreadsheets/d/XXXXXXXXXXXXXXXXXXXXXXXX/edit"

# --- Option A: Service Account (enables read AND write) --------------------
# Paste the values from the JSON key file you download from Google Cloud.
# Keep the private_key exactly as-is, including the literal \n line breaks.
type                        = "service_account"
project_id                  = "your-gcp-project-id"
private_key_id              = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
private_key                 = "-----BEGIN PRIVATE KEY-----\nMIIE...your key...==\n-----END PRIVATE KEY-----\n"
client_email                = "capacity-app@your-gcp-project-id.iam.gserviceaccount.com"
client_id                   = "1234567890"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/capacity-app%40your-gcp-project-id.iam.gserviceaccount.com"

# --- Option B: Public sheet (read-only) ------------------------------------
# If you only want read-only access to a sheet shared as "Anyone with the link",
# delete the whole service-account block above and keep just `spreadsheet`.
